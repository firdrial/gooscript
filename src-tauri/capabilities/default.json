{
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-close",
    "core:window:allow-destroy",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:default",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-write-file",
    "shell:allow-open"
  ],
  "scope": {
    "fs": {
      "allow": [
        "**",
        "$TEMP/**",
        "$TEMP/*",
        "$TEMP/*.*"
      ]
    }
  }
}